<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="YAHAA.Setup.Steps.WelcomeStep"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,32" MaxWidth="460" VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel Spacing="16" HorizontalAlignment="Stretch">
            <TextBlock Text="Welcome to YAHAA"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       FontSize="28"
                       FontWeight="Bold" />
            <TextBlock Text="Yet Another Home Assistant App. Let's connect to your home to get started."
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       FontSize="15"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <Button x:Name="GetStartedButton"
                    Click="GetStarted_Click"
                    Content="Get started"
                    HorizontalAlignment="Stretch"
                    Margin="0,16,0,0"
                    Height="44"
                    CornerRadius="8"
                    Foreground="White"
                    Background="{StaticResource HaBlueBrush}"
                    FontWeight="SemiBold" />
        </StackPanel>
    </Grid>
</Page>
