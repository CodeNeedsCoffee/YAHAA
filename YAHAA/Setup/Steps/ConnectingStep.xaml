<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="YAHAA.Setup.Steps.ConnectingStep"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,32" MaxWidth="460" VerticalAlignment="Center" HorizontalAlignment="Center">

        <!-- Busy -->
        <StackPanel x:Name="BusyPanel" Spacing="20" HorizontalAlignment="Center">
            <ProgressRing Width="48" Height="48" IsActive="True"
                          Foreground="{StaticResource HaBlueBrush}"
                          HorizontalAlignment="Center" />
            <TextBlock x:Name="BusyText"
                       Text="Connecting…"
                       FontSize="16"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Success -->
        <StackPanel x:Name="SuccessPanel" Spacing="16" HorizontalAlignment="Center" Visibility="Collapsed">
            <Border Width="72" Height="72" CornerRadius="36"
                    Background="#FF2E7D32" HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE73E;" FontSize="34" Foreground="White" />
            </Border>
            <TextBlock x:Name="SuccessTitle"
                       Text="Connected!"
                       FontSize="22"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="SuccessSubtitle"
                       FontSize="14"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Error -->
        <StackPanel x:Name="ErrorPanel" Spacing="16" HorizontalAlignment="Stretch" Visibility="Collapsed">
            <Border Width="72" Height="72" CornerRadius="36"
                    Background="#FFC62828" HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE783;" FontSize="34" Foreground="White" />
            </Border>
            <TextBlock Text="Couldn't connect"
                       FontSize="22"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="ErrorText"
                       FontSize="14"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <Button Content="Edit details"
                    Click="EditDetails_Click"
                    HorizontalAlignment="Stretch"
                    Margin="0,8,0,0"
                    Height="44"
                    CornerRadius="8"
                    Foreground="White"
                    Background="{StaticResource HaBlueBrush}"
                    FontWeight="SemiBold" />
        </StackPanel>
    </Grid>
</Page>
