<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="YAHAA.Setup.Steps.CredentialsStep"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,32" MaxWidth="460" VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel Spacing="14" HorizontalAlignment="Stretch">
            <TextBlock Text="Sign in"
                       FontSize="24"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Provide your username and a long-lived access token."
                       FontSize="14"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <TextBox x:Name="UsernameBox"
                     Header="Username"
                     PlaceholderText="e.g. evan"
                     Margin="0,8,0,0" />

            <TextBox x:Name="DeviceNameBox"
                     Header="Device name"
                     PlaceholderText="Name shown in Home Assistant" />

            <PasswordBox x:Name="TokenBox"
                         Header="Long-lived access token"
                         PlaceholderText="Paste your token" />

            <HyperlinkButton Content="How do I create a long-lived access token?"
                             NavigateUri="https://www.home-assistant.io/docs/authentication/#your-account-profile"
                             Padding="0,2"
                             FontSize="13" />

            <InfoBar x:Name="ErrorBar"
                     IsOpen="False"
                     IsClosable="False"
                     Severity="Error"
                     Margin="0,2,0,0" />

            <Button x:Name="ContinueButton"
                    Click="Continue_Click"
                    Content="Sign in"
                    HorizontalAlignment="Stretch"
                    Margin="0,8,0,0"
                    Height="44"
                    CornerRadius="8"
                    Foreground="White"
                    Background="{StaticResource HaBlueBrush}"
                    FontWeight="SemiBold" />

            <Button Content="Back"
                    Click="Back_Click"
                    HorizontalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0" />
        </StackPanel>
    </Grid>
</Page>
