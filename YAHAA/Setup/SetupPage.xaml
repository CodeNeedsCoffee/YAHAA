<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="YAHAA.Setup.SetupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- A soft HA-blue glow at the top sits over the window's Mica backdrop and stays put
         while the step content slides beneath it. -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Offset="0.0" Color="{StaticResource HaBlueGlow}" />
                <GradientStop Offset="0.55" Color="Transparent" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Constant brand header -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,56,0,0" Spacing="14">
            <Border Width="76" Height="76" CornerRadius="22"
                    HorizontalAlignment="Center">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <Image x:Name="HeaderLogo" Width="76" Height="76" Stretch="UniformToFill" />
            </Border>
            <TextBlock Text="YAHAA"
                       HorizontalAlignment="Center"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Sliding step content -->
        <Frame x:Name="StepFrame" Grid.Row="1" />

        <!-- Step progress dots -->
        <StackPanel x:Name="DotsPanel" Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,44"
                    Spacing="8" />
    </Grid>
</Page>
