<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="YAHAA.Shell.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="40,32">
        <StackPanel Spacing="20" MaxWidth="640" HorizontalAlignment="Left">
            <TextBlock Text="Settings" FontSize="30" FontWeight="Bold" />

            <!-- Connection card -->
            <Border CornerRadius="12"
                    Padding="24"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="14">
                    <TextBlock Text="Home Assistant connection" FontSize="18" FontWeight="SemiBold" />

                    <TextBox x:Name="UrlBox"
                             Header="Home Assistant URL"
                             PlaceholderText="http://homeassistant.local:8123" />

                    <TextBox x:Name="UsernameBox"
                             Header="Username"
                             PlaceholderText="e.g. evan" />

                    <PasswordBox x:Name="TokenBox"
                                 Header="Long-lived access token"
                                 PlaceholderText="Paste your token" />

                    <InfoBar x:Name="ResultBar" IsOpen="False" IsClosable="True" />

                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
                        <Button x:Name="TestButton" Click="Test_Click" Content="Test connection" />
                        <Button x:Name="SaveButton" Click="Save_Click"
                                Content="Save changes"
                                Foreground="White"
                                Background="{StaticResource HaBlueBrush}"
                                FontWeight="SemiBold" />
                        <ProgressRing x:Name="BusyRing" Width="22" Height="22"
                                      IsActive="False" Visibility="Collapsed"
                                      VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Device card -->
            <Border CornerRadius="12"
                    Padding="24"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="14">
                    <TextBlock Text="Device" FontSize="18" FontWeight="SemiBold" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Report this device to Home Assistant" />
                            <TextBlock x:Name="ReportStatusText"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="ReportToggle"
                                      Grid.Column="1"
                                      Toggled="ReportToggle_Toggled" />
                    </Grid>

                    <TextBox x:Name="DeviceNameBox"
                             Header="Device name"
                             PlaceholderText="Name shown in Home Assistant"
                             LostFocus="DeviceNameBox_LostFocus" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="App version:"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="AppVersionText" />
                    </StackPanel>

                    <NumberBox x:Name="IdleBox"
                               Header="Report inactive after (minutes of no input)"
                               Minimum="1"
                               Maximum="240"
                               SmallChange="1"
                               SpinButtonPlacementMode="Inline"
                               ValueChanged="IdleBox_ValueChanged" />

                    <StackPanel Spacing="2">
                        <TextBlock x:Name="DebounceLabel" />
                        <Slider x:Name="DebounceSlider"
                                Minimum="3"
                                Maximum="30"
                                StepFrequency="1"
                                TickFrequency="3"
                                TickPlacement="Outside"
                                ValueChanged="DebounceSlider_ValueChanged" />
                        <TextBlock Text="A change must hold this long before it's reported, so brief activity doesn't cause flapping."
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <TextBlock x:Name="ActiveNowText"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Location card -->
            <Border CornerRadius="12"
                    Padding="24"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="14">
                    <TextBlock Text="Location" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="Report this PC's location to Home Assistant as diagnostic sensors on the device. Turning this on asks Windows for location permission."
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Track location" VerticalAlignment="Center" />
                            <TextBlock x:Name="LocationStatusText"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="LocationToggle"
                                      Grid.Column="1"
                                      Toggled="LocationToggle_Toggled" />
                    </Grid>

                    <InfoBar x:Name="LocationInfoBar" IsOpen="False" IsClosable="True" />
                </StackPanel>
            </Border>

            <!-- Appearance card -->
            <Border CornerRadius="12"
                    Padding="24"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="14">
                    <TextBlock Text="Appearance" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="Choose which logo YAHAA shows in the title bar and setup screens."
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <RadioButtons x:Name="LogoChoice"
                                  MaxColumns="2"
                                  SelectionChanged="LogoChoice_SelectionChanged">
                        <RadioButton>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Width="40" Height="40" CornerRadius="10">
                                    <Image Source="ms-appx:///Assets/Logo-HA.png" Stretch="UniformToFill" />
                                </Border>
                                <TextBlock Text="HA" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Width="40" Height="40" CornerRadius="10">
                                    <Image Source="ms-appx:///Assets/Logo-YAHAA.png" Stretch="UniformToFill" />
                                </Border>
                                <TextBlock Text="YAHAA" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                    </RadioButtons>
                </StackPanel>
            </Border>

            <!-- Scripts card -->
            <Border CornerRadius="12"
                    Padding="24"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="14">
                    <TextBlock Text="Scripts" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="Expose a folder of .ps1 / .bat scripts as buttons in Home Assistant."
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Enable scripts" VerticalAlignment="Center" />
                        <ToggleSwitch x:Name="ScriptsToggle"
                                      Grid.Column="1"
                                      Toggled="ScriptsToggle_Toggled" />
                    </Grid>

                    <StackPanel x:Name="ScriptsFolderPanel" Spacing="6">
                        <TextBlock Text="Scripts folder"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ScriptsFolderText"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       IsTextSelectionEnabled="True" />
                            <Button x:Name="ChooseFolderButton"
                                    Grid.Column="1"
                                    Margin="12,0,0,0"
                                    Content="Choose folder…"
                                    Click="ChooseFolder_Click" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Setup card -->
            <Border CornerRadius="12"
                    Padding="24"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="14">
                    <TextBlock Text="Setup" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="Re-run the guided setup wizard, or sign out to remove this connection from this PC."
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="RerunButton" Click="Rerun_Click" Content="Re-run setup wizard" />
                        <Button x:Name="SignOutButton" Click="SignOut_Click" Content="Sign out" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
