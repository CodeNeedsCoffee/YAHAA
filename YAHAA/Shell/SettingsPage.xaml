<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="YAHAA.Shell.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="40,32">
        <StackPanel Spacing="20" MaxWidth="640" HorizontalAlignment="Left">
            <TextBlock Text="Settings" FontSize="30" FontWeight="Bold" />

            <!-- Connection card -->
            <Border CornerRadius="12"
                    Padding="24"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="14">
                    <TextBlock Text="Home Assistant connection" FontSize="18" FontWeight="SemiBold" />

                    <TextBox x:Name="UrlBox"
                             Header="Home Assistant URL"
                             PlaceholderText="http://homeassistant.local:8123" />

                    <TextBox x:Name="UsernameBox"
                             Header="Username"
                             PlaceholderText="e.g. evan" />

                    <PasswordBox x:Name="TokenBox"
                                 Header="Long-lived access token"
                                 PlaceholderText="Paste your token" />

                    <InfoBar x:Name="ResultBar" IsOpen="False" IsClosable="True" />

                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
                        <Button x:Name="TestButton" Click="Test_Click" Content="Test connection" />
                        <Button x:Name="SaveButton" Click="Save_Click"
                                Content="Save changes"
                                Foreground="White"
                                Background="{StaticResource HaBlueBrush}"
                                FontWeight="SemiBold" />
                        <ProgressRing x:Name="BusyRing" Width="22" Height="22"
                                      IsActive="False" Visibility="Collapsed"
                                      VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Setup card -->
            <Border CornerRadius="12"
                    Padding="24"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="14">
                    <TextBlock Text="Setup" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="Re-run the guided setup wizard, or sign out to remove this connection from this PC."
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="RerunButton" Click="Rerun_Click" Content="Re-run setup wizard" />
                        <Button x:Name="SignOutButton" Click="SignOut_Click" Content="Sign out" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
