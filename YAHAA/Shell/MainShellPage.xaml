<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="YAHAA.Shell.MainShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <NavigationView x:Name="Nav"
                    IsBackButtonVisible="Collapsed"
                    IsSettingsVisible="True"
                    PaneDisplayMode="Left"
                    SelectionChanged="Nav_SelectionChanged"
                    Loaded="Nav_Loaded">
        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="HomeItem" Content="Home" Tag="home">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE80F;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="ScriptsItem" Content="Scripts" Tag="scripts" Visibility="Collapsed">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE756;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Page>
