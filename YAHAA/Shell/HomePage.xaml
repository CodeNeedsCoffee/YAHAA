<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="YAHAA.Shell.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="40">
        <StackPanel Spacing="20" MaxWidth="560" HorizontalAlignment="Left" VerticalAlignment="Top">
            <TextBlock x:Name="Greeting" FontSize="30" FontWeight="Bold" />

            <Border CornerRadius="12"
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="10" Height="10" CornerRadius="5" Background="#FF2E7D32"
                                VerticalAlignment="Center" />
                        <TextBlock Text="Connected" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock x:Name="ServerText"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               IsTextSelectionEnabled="True" />
                </StackPanel>
            </Border>

            <TextBlock Text="Your dashboards will appear here. For now you can manage your connection from Settings."
                       TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </Grid>
</Page>
