<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="YAHAA.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:YAHAA">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>

            <!-- Home Assistant brand palette -->
            <Color x:Key="HaBlue">#FF03A9F4</Color>
            <Color x:Key="HaBlueDark">#FF0288D1</Color>
            <Color x:Key="HaBlueGlow">#3303A9F4</Color>
            <SolidColorBrush x:Key="HaBlueBrush" Color="{StaticResource HaBlue}" />
            <SolidColorBrush x:Key="HaBlueDarkBrush" Color="{StaticResource HaBlueDark}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
