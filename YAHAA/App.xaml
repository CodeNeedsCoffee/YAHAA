<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="YAHAA.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:YAHAA">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>

            <!-- Home Assistant brand palette -->
            <SolidColorBrush x:Key="HaBlueBrush" Color="#FF03A9F4"/>
            <SolidColorBrush x:Key="HaBlueDarkBrush" Color="#FF0288D1"/>
            <SolidColorBrush x:Key="HaBlueGlowBrush" Color="#3303A9F4"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
