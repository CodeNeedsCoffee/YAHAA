<?xml version="1.0" encoding="utf-8"?>
<!--
  Store upload profile — produces a .msixupload file suitable for Partner Center submission.

  Prerequisites before building:
    1. Reserve your app name in Partner Center (https://partner.microsoft.com/dashboard).
    2. Copy the "Package identity" values from: App management > Product identity.
    3. Update Package.appxmanifest:
         <Identity Name="<PackageIdentityName>"
                   Publisher="<PublisherDN>"
                   Version="x.y.z.0" />
         <Properties>
           <PublisherDisplayName>Your Display Name</PublisherDisplayName>
         </Properties>

  Build command (run from the repo root). Restore and Publish MUST be separate
  MSBuild invocations: combining them (e.g. /t:Restore,Publish) does not re-evaluate
  the project between them, so on a clean tree the Windows App SDK / XAML compiler
  targets aren't imported and every page fails with "InitializeComponent does not exist".
  AppxBundle / AppxBundlePlatforms are already set in this profile.

    msbuild YAHAA\YAHAA.csproj /p:Configuration=Release /p:Platform=x64 /t:Restore
    msbuild YAHAA\YAHAA.csproj /p:Configuration=Release /p:Platform=x64 /p:PublishProfile=store-upload /t:Publish

  Output: YAHAA\AppPackages\  →  YAHAA_<version>_x86_x64_arm64_bundle.msixupload
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <Platform>x64</Platform>
    <!--
      Do NOT pin RuntimeIdentifier here. The bundle build recursively builds x86 and
      arm64 passing only Platform=<arch>; a pinned RID leaks down as a global property
      and fails NETSDK1032. The csproj maps Platform -> RID per architecture instead.
    -->
    <PublishDir>bin\Release\store-upload\</PublishDir>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>False</PublishSingleFile>

    <!-- Store submission: Partner Center signs the package; local signing must be off -->
    <AppxPackageSigningEnabled>false</AppxPackageSigningEnabled>

    <!--
      Skip the .appxsym symbol package. Generating it requires the C++ mspdbcmf.exe
      tool (VS "Desktop development with C++" workload), which isn't installed; without
      it the symbol task fails with MSB6011. Symbols are optional for Store submission
      and can be re-enabled after installing the C++ build tools.
    -->
    <AppxSymbolPackageEnabled>false</AppxSymbolPackageEnabled>

    <!-- StoreUpload produces a .msixupload archive (bundle + symbols) ready for Partner Center -->
    <UapAppxPackageBuildMode>StoreUpload</UapAppxPackageBuildMode>

    <!-- Bundle all three architectures into a single submission file -->
    <AppxBundle>Always</AppxBundle>
    <AppxBundlePlatforms>x86|x64|arm64</AppxBundlePlatforms>

    <!-- Emit the package as part of the build/publish target -->
    <GenerateAppxPackageOnBuild>true</GenerateAppxPackageOnBuild>
  </PropertyGroup>
</Project>
